{
  "manifest_version": 3,
  "name": "ChatNotion",
  "version": "1.0.0",
  "description": "Organize ChatGPT chats into editable knowledge trees, and edit the original answers into your own private notes.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "unlimitedStorage"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/vendor/katex/katex.min.js",
        "src/core.js",
        "src/markdown.js",
        "src/outline.js",
        "src/prompts.js",
        "src/custom-tools.js",
        "src/branch-policy.js",
        "src/drag-scroll.js",
        "src/marquee.js",
        "src/input-isolation.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/panel.css",
        "src/vendor/katex/katex.min.css",
        "src/vendor/katex/katex-fonts.css",
        "src/vendor/katex/fonts/*"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src 'none'"
  }
}
